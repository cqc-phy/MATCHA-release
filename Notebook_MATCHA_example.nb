              SuperscriptBox["s", "2"], "-", "1"}], ")"}], " ", "v", " ", 
            "vs"}]}], ")"}]}], 
        RowBox[{"12", " ", 
         SuperscriptBox["Mw", "2"], " ", "SW2", " ", 
         SuperscriptBox["vs", "2"]}]]}]},
     {"\<\"c1\"\>", "c"},
     {"\<\"c2\"\>", 
