Cell[BoxData[
 FormBox[
  TagBox[GridBox[{
     {"\<\"HEFT coefficient\"\>", "\<\"Matching Expression\"\>"},
     {"\<\"d3\"\>", 
      RowBox[{
       SuperscriptBox["c", "3"], "-", 
       FractionBox[
        RowBox[{
         SuperscriptBox["s", "3"], " ", "v"}], "vs"]}]},
     {"\<\"d4\"\>", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{
         RowBox[{"-", 
          RowBox[{"3", " ", 
           SuperscriptBox["c", "6"], " ", 
           SuperscriptBox["vs", "2"]}]}], "+", 
         RowBox[{"16", " ", 
          SuperscriptBox["c", "4"], " ", 
          SuperscriptBox["s", "2"], " ", 
          SuperscriptBox["vs", "2"]}], "+", 
         RowBox[{"38", " ", 
          SuperscriptBox["c", "3"], " ", 
          SuperscriptBox["s", "3"], " ", "v", " ", "vs"}], "+", 
         RowBox[{"16", " ", 
          SuperscriptBox["c", "2"], " ", 
          SuperscriptBox["s", "4"], " ", 
          SuperscriptBox["v", "2"]}], "-", 
         RowBox[{"3", " ", 
          SuperscriptBox["s", "6"], " ", 
          SuperscriptBox["v", "2"]}]}], 
        RowBox[{"3", " ", 
         SuperscriptBox["vs", "2"]}]]}]},
     {"\<\"d5\"\>", 
      FractionBox[
       RowBox[{
        SuperscriptBox["c", "2"], " ", 
        SuperscriptBox["s", "2"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"c", " ", "vs"}], "+", 
           RowBox[{"s", " ", "v"}]}], ")"}], "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["c", "3"], " ", 
           RowBox[{"(", 
            RowBox[{"-", "vs"}], ")"}]}], "-", 
          RowBox[{"2", " ", 
           SuperscriptBox["c", "2"], " ", "s", " ", "v"}], "+", 
          RowBox[{"2", " ", "c", " ", 
           SuperscriptBox["s", "2"], " ", "vs"}], "+", 
          RowBox[{
           SuperscriptBox["s", "3"], " ", "v"}]}], ")"}]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["vs", "3"]}]]},
     {"\<\"a1\"\>", 
      FractionBox[
       RowBox[{"c", " ", 
        SuperscriptBox["e", "2"], " ", 
        SuperscriptBox["v", "2"]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["Mw", "2"], " ", "SW2"}]]},
     {"\<\"a2\"\>", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"c", " ", 
         SuperscriptBox["e", "2"], " ", 
         SuperscriptBox["v", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"c", " ", 
            SuperscriptBox["s", "2"], " ", "vs"}], "-", 
           RowBox[{"c", " ", "vs"}], "+", 
           RowBox[{
            SuperscriptBox["s", "3"], " ", "v"}]}], ")"}]}], 
        RowBox[{"4", " ", 
         SuperscriptBox["Mw", "2"], " ", "SW2", " ", "vs"}]]}]},
     {"\<\"a3\"\>", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SuperscriptBox["e", "2"], " ", 
         SuperscriptBox["s", "2"], " ", 
         SuperscriptBox["v", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox["c", "3"], " ", 
            SuperscriptBox["vs", "2"]}], "+", 
           RowBox[{"5", " ", 
            SuperscriptBox["c", "2"], " ", "s", " ", "v", " ", "vs"}], "+", 
           RowBox[{"c", " ", 
            SuperscriptBox["s", "2"], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"4", " ", 
